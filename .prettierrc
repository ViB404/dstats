{
    "arrowParens": "avoid",
    "printWidth": 120,
    "tabWidth": 4,
    "trailingComma": "es5",
    "useTabs": true,
    "overrides": [
        {
            "files": "*.{yml,yaml,md}",
            "options": {
                "tabWidth": 2,
                "useTabs": false
            }
        }
    ]
}