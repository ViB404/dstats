{
	"name": "dstats",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"format": "prettier --write . && pnpm --filter api format",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "husky",
		"typecheck": "turbo typecheck",
		"knip": "knip",
		"validate": "pnpm run typecheck && pnpm run lint && pnpm run knip",
		"dev": "turbo dev",
		"build": "turbo build",
		"start": "turbo start"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ViB404/dstats.git"
	},
	"bugs": {
		"url": "https://github.com/ViB404/dstats/issues"
	},
	"author": {
		"name": "ViB",
		"url": "https://github.com/ViB404"
	},
	"contributors": [],
	"homepage": "https://dstats.havochz.xyz/",
	"funding": "https://ko-fi.com/vib404",
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		],
		"*.rs": [
			"sh -c 'cargo fmt --manifest-path apps/api/Cargo.toml --all'"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.6.0",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"husky": "^9.1.7",
		"knip": "^6.24.0",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.4",
		"tsup": "^8.5.1",
		"turbo": "^2.10.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.1",
		"unplugin-replace": "^0.9.0"
	}
}
