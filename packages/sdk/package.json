{
  "name": "@dstats/sdk",
  "description": "Official TypeScript SDK for DStats. Collect Discord bot analytics with a simple adapter-based API.",
  "version": "0.0.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "author": {
    "name": "ViB",
    "url": "https://github.com/ViB404"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ViB404/dstats.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://dstats.havochz.xyz",
  "bugs": {
    "url": "https://github.com/ViB404/dstats/issues"
  },
  "keywords": [
    "dstats",
    "discord",
    "discord-bot",
    "discord.js",
    "analytics",
    "metrics",
    "telemetry",
    "statistics",
    "sdk",
    "typescript",
    "nodejs",
    "bot"
  ]
}
