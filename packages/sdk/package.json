{
	"name": "@dstats/sdk",
	"description": "Official TypeScript SDK for DStats. Collect Discord bot analytics with a simple adapter-based API.",
	"version": "0.0.2",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"build:watch": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ViB404/dstats.git",
		"directory": "packages/sdk"
	},
	"bugs": {
		"url": "https://github.com/ViB404/dstats/issues"
	},
	"author": {
		"name": "ViB",
		"url": "https://github.com/ViB404"
	},
	"contributors": [],
	"homepage": "https://dstats.havochz.xyz",
	"funding": "https://ko-fi.com/vib404",
	"keywords": [
		"dstats",
		"discord",
		"discord-bot",
		"discord.js",
		"analytics",
		"metrics",
		"telemetry",
		"statistics",
		"sdk",
		"typescript",
		"nodejs",
		"bot"
	],
	"devDependencies": {
		"@types/node": "^22.20.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
